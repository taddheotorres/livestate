# ============================
# Livestate - Environment Variables
# ============================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=real_estate_db

# Stripe (get your keys at https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=

# JWT Secret (generate with: openssl rand -base64 64)
JWT_SECRET=

# Backend
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/real_estate_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# Frontend (URL where the app is publicly accessible)
APP_BASE_URL=http://localhost:4200
